{
  "name": "agent-remnote",
  "version": "1.3.3",
  "license": "MIT",
  "bin": {
    "agent-remnote": "./cli.js"
  },
  "files": [
    "cli.js",
    "dist",
    "plugin-artifacts",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "scripts": {
    "prepare:plugin-artifacts": "node --import tsx ./scripts/prepare-plugin-artifacts.ts",
    "cli": "node --import tsx ./src/main.ts",
    "dev": "node --import tsx ./src/main.ts",
    "build": "npm run prepare:plugin-artifacts && bun build ./src/main.ts --target node --packages bundle --external better-sqlite3 --outdir dist",
    "build:verified": "npm run build && node ./scripts/assert-bundled-effect-cli-patch.js",
    "smoke:dist": "npm run build && node ./cli.js --help",
    "prepack": "npm run build:verified",
    "bench:nfr-004": "node --import tsx ./scripts/bench-nfr-004.ts",
    "gate:nfr-004": "node --import tsx ./scripts/bench-nfr-004.ts --check",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint --config ../../.oxlintrc.json --ignore-path ../../.eslintignore .",
    "format": "oxfmt -c ../../.oxfmtrc.json --ignore-path ../../.gitignore --ignore-path ../../.prettierignore .",
    "format:check": "oxfmt -c ../../.oxfmtrc.json --ignore-path ../../.gitignore --ignore-path ../../.prettierignore --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1"
  },
  "devDependencies": {
    "@effect/cli": "0.73.1",
    "@effect/platform": "0.94.2",
    "@effect/platform-node": "0.104.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.30",
    "@types/ws": "^8.18.1",
    "date-fns": "^4.1.0",
    "effect": "3.19.15",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.0",
    "unified": "^11.0.0",
    "vitest": "^2.1.8",
    "zod": "3.23.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yoyooyooo/agent-remnote.git",
    "directory": "packages/agent-remnote"
  },
  "homepage": "https://github.com/yoyooyooo/agent-remnote",
  "bugs": {
    "url": "https://github.com/yoyooyooo/agent-remnote/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
