{
  "name": "@remnote/plugin",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "check-types": "tsc --noEmit",
    "clean": "shx rm -rf dist PluginZip.zip",
    "dev": "vite",
    "build": "npm run clean && vite build && npm run zip",
    "zip": "cd dist && bestzip ../PluginZip.zip ./*",
    "typecheck": "npm run check-types",
    "lint": "oxlint --config ../../.oxlintrc.json --ignore-path ../../.eslintignore .",
    "format": "oxfmt -c ../../.oxfmtrc.json --ignore-path ../../.gitignore --ignore-path ../../.prettierignore .",
    "format:check": "oxfmt -c ../../.oxfmtrc.json --ignore-path ../../.gitignore --ignore-path ../../.prettierignore --check .",
    "test": "node --test tests/**/*.test.mjs"
  },
  "dependencies": {
    "@remnote/plugin-sdk": "latest",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^17.0.2",
    "@types/react-dom": "^17.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.7",
    "bestzip": "^2.2.1",
    "postcss": "^8.4.14",
    "postcss-import": "^14.1.0",
    "shx": "^0.3.4",
    "tailwindcss": "^3.1.5",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
