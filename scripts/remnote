#!/usr/bin/env bash
set -euo pipefail

die() {
  echo "ERROR: $*" >&2
  exit 1
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

command -v bun >/dev/null 2>&1 || die "缺少 bun（用于运行 remnote CLI）"

cd "$REPO_ROOT"
exec bun packages/agent-remnote/src/main.ts "$@"
