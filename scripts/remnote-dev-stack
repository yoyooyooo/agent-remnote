#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/remnote-dev-env.sh"

if [[ "${1:-}" == "stack" ]]; then
  shift
fi

command_name="${1:-}"
shift || true

emit_combined_json() {
  local mode="$1"
  local daemon_json="$2"
  local api_json="$3"
  local plugin_json="$4"
  local active_worker="${5:-}"

  node - "$mode" "$daemon_json" "$api_json" "$plugin_json" "$active_worker" "$(remnote_dev_root_dir)" "$(remnote_dev_ws_url)" "$REMNOTE_API_PORT" "$REMNOTE_PLUGIN_SERVER_PORT" <<'NODE'
const [mode, daemonRaw, apiRaw, pluginRaw, activeWorkerRaw, devRoot, wsUrl, apiPortRaw, pluginPortRaw] = process.argv.slice(2);
const daemon = JSON.parse(daemonRaw);
const api = JSON.parse(apiRaw);
const plugin = JSON.parse(pluginRaw);
const ok = Boolean(daemon?.ok && api?.ok && plugin?.ok);
const activeWorker = typeof activeWorkerRaw === 'string' && activeWorkerRaw.trim() ? activeWorkerRaw : null;
const normalizedPlugin =
  plugin?.data?.service?.running || plugin?.data?.state
    ? plugin?.data ?? null
    : {
        ...(plugin?.data ?? {}),
        plugin_server: {
          ...(plugin?.data?.plugin_server ?? {}),
          healthy: false,
          base_url: `http://127.0.0.1:${Number(pluginPortRaw)}`,
          host: '127.0.0.1',
          port: Number(pluginPortRaw),
          error: 'isolated plugin server is not running',
        },
      };
const payload = {
  ok,
  data: {
    mode,
    dev_root: devRoot,
    ws_url: wsUrl,
    api_port: Number(apiPortRaw),
    plugin_port: Number(pluginPortRaw),
    active_worker_conn_id: activeWorker,
    daemon: daemon?.data ?? null,
    api: api?.data ?? null,
    plugin: normalizedPlugin,
  },
};
console.log(JSON.stringify(payload, null, 2));
process.exit(ok ? 0 : 1);
NODE
}

extract_active_worker() {
  local daemon_json="$1"
  node -e 'const data = JSON.parse(process.argv[1]); process.stdout.write(typeof data?.data?.active_worker_conn_id === "string" ? data.data.active_worker_conn_id : "")' "$daemon_json"
}

wait_for_active_worker() {
  local timeout_ms="$1"
  local started_at
  started_at="$(node -e 'process.stdout.write(String(Date.now()))')"

  while true; do
    local daemon_status_json active_worker now
    daemon_status_json="$("$SCRIPT_DIR/remnote-dev" --json daemon status --pid-file "$REMNOTE_DAEMON_PID_FILE")"
    active_worker="$(extract_active_worker "$daemon_status_json")"
    if [[ -n "$active_worker" ]]; then
      printf '%s\n' "$active_worker"
      return 0
    fi

    now="$(node -e 'process.stdout.write(String(Date.now()))')"
    if (( now - started_at >= timeout_ms )); then
      return 1
    fi
    sleep 1
  done
}

case "$command_name" in
  ensure)
    wait_worker=0
    worker_timeout_ms=15000
    while (($# > 0)); do
      case "$1" in
        --wait-worker)
          wait_worker=1
          shift
          ;;
        --worker-timeout-ms)
          if [[ -z "${2:-}" || "${2:-}" == --* ]]; then
            echo "Missing value for --worker-timeout-ms" >&2
            exit 2
          fi
          worker_timeout_ms="$2"
          shift 2
          ;;
        *)
          echo "Unsupported remnote-dev-stack ensure arg: $1" >&2
          exit 2
          ;;
      esac
    done

    daemon_json="$("$SCRIPT_DIR/remnote-dev" --json daemon ensure --pid-file "$REMNOTE_DAEMON_PID_FILE" --log-file "$REMNOTE_DAEMON_LOG_FILE")"
    api_json="$("$SCRIPT_DIR/remnote-dev" --json api ensure --host "$REMNOTE_API_HOST" --port "$REMNOTE_API_PORT" --pid-file "$REMNOTE_API_PID_FILE" --log-file "$REMNOTE_API_LOG_FILE" --state-file "$REMNOTE_API_STATE_FILE")"
    plugin_json="$("$SCRIPT_DIR/remnote-dev" --json plugin ensure --host 127.0.0.1 --port "$REMNOTE_PLUGIN_SERVER_PORT" --pid-file "$REMNOTE_PLUGIN_SERVER_PID_FILE" --log-file "$REMNOTE_PLUGIN_SERVER_LOG_FILE" --state-file "$REMNOTE_PLUGIN_SERVER_STATE_FILE")"

    active_worker=""
    if [[ "$wait_worker" == "1" ]]; then
      active_worker="$(wait_for_active_worker "$worker_timeout_ms")" || {
        echo "Timed out waiting for an active worker (${worker_timeout_ms}ms)" >&2
        exit 1
      }
    fi

    emit_combined_json ensure "$daemon_json" "$api_json" "$plugin_json" "$active_worker"
    ;;
  status)
    daemon_json="$("$SCRIPT_DIR/remnote-dev" --json daemon status --pid-file "$REMNOTE_DAEMON_PID_FILE")"
    api_json="$("$SCRIPT_DIR/remnote-dev" --json api status --pid-file "$REMNOTE_API_PID_FILE" --state-file "$REMNOTE_API_STATE_FILE")"
    plugin_json="$("$SCRIPT_DIR/remnote-dev" --json plugin status --pid-file "$REMNOTE_PLUGIN_SERVER_PID_FILE" --state-file "$REMNOTE_PLUGIN_SERVER_STATE_FILE")"
    emit_combined_json status "$daemon_json" "$api_json" "$plugin_json" "$(extract_active_worker "$daemon_json")"
    ;;
  stop)
    plugin_json="$("$SCRIPT_DIR/remnote-dev" --json plugin stop --force --pid-file "$REMNOTE_PLUGIN_SERVER_PID_FILE" --state-file "$REMNOTE_PLUGIN_SERVER_STATE_FILE")"
    api_json="$("$SCRIPT_DIR/remnote-dev" --json api stop --force --pid-file "$REMNOTE_API_PID_FILE" --state-file "$REMNOTE_API_STATE_FILE")"
    daemon_json="$("$SCRIPT_DIR/remnote-dev" --json daemon stop --force --pid-file "$REMNOTE_DAEMON_PID_FILE")"
    emit_combined_json stop "$daemon_json" "$api_json" "$plugin_json" ""
    ;;
  *)
    echo "Usage: scripts/remnote-dev-stack [stack] <ensure|status|stop> [--wait-worker --worker-timeout-ms <ms>]" >&2
    exit 2
    ;;
esac
