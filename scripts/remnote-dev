#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/remnote-dev-env.sh"

args=("$@")

if [[ "${args[0]:-}" == "stack" && $# -ge 2 ]]; then
  case "${args[1]:-}" in
    ensure|status|stop)
      exec "$SCRIPT_DIR/remnote-dev-stack" "${args[@]}"
      ;;
  esac
fi

if [[ "${args[0]:-}" == "plugin" ]]; then
  case "${args[1]:-}" in
    start|ensure|restart|serve)
      if ! remnote_dev_has_arg --port "${args[@]}"; then
        args+=(--port "$REMNOTE_PLUGIN_SERVER_PORT")
      fi
      if ! remnote_dev_has_arg --host "${args[@]}"; then
        args+=(--host 127.0.0.1)
      fi
      ;;
  esac
fi

cd "$(remnote_dev_repo_root)"
exec node --import tsx packages/agent-remnote/src/main.ts \
  --daemon-url "$(remnote_dev_ws_url)" \
  --api-host "$REMNOTE_API_HOST" \
  --api-port "$REMNOTE_API_PORT" \
  --repo "$AGENT_REMNOTE_REPO" \
  "${args[@]}"
